PORT=3000

# MySQL — use the same DB name locally and in production (create empty DB in hosting panel first)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=shakyaco_gg

# Production (Render → remote MySQL): set DB_SKIP_CREATE=true, DB_HOST=your-mysql-host
# DB_SKIP_CREATE=true

GGP_SECRET_KEY=your_jwt_secret
VALID_API_KEYS=12345-abcde,67890-fghij,ggp-pro-ject

ADMIN_EMAIL=admin@goodgut.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=GGP Admin

# SaaS subscription (Razorpay) — 15-day trial, then ₹1000/year
TRIAL_DAYS=15
SUBSCRIPTION_PRICE_INR=1000
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Jitsi Meet video calls
JITSI_DOMAIN=meet.jit.si
JITSI_ROOM_PREFIX=goodgut-call
CALL_JOIN_MINUTES_BEFORE=15
CALL_JOIN_MINUTES_AFTER=60

# Comma-separated portal URLs allowed by CORS (optional; also set in server.js)
# CORS_ORIGINS=https://ggp-navy.vercel.app
